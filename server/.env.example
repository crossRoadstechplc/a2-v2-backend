# Server
PORT=3049
NODE_ENV=development

# Database
DATABASE_PATH=./data/a2-gateway.db

# Rate limiting (requests per 15 minutes per IP)
RATE_LIMIT_MAX=100

# OTP request limit (per 15 minutes per IP)
OTP_REQUEST_LIMIT=5

# Email (for OTP)
SMTP_HOST=mail.a2ecorridor.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=register@a2ecorridor.com
SMTP_PASS=gamma@2026!!
MAIL_FROM="A2E Corridor" <register@a2ecorridor.com>

# Set to true to capture OTP in memory instead of sending (dev/test)
MAIL_TEST_MODE=false
