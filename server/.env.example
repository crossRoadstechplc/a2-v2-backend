# =============================================================================
# A2 Simulator Gateway - Environment Variables
# =============================================================================
# Copy to .env and adjust for your environment.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=development

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# SQLite database file path. Directory is created if missing.
DATABASE_PATH=./data/a2-gateway.db

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
# Global: max requests per IP per 15 minutes
RATE_LIMIT_MAX=100

# OTP endpoint: max request-otp calls per IP per 15 minutes
OTP_REQUEST_LIMIT=5

# -----------------------------------------------------------------------------
# Email (OTP delivery)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@example.com

# Capture OTP in memory instead of sending (dev/test only)
# Set to true for local testing without real SMTP
MAIL_TEST_MODE=false
